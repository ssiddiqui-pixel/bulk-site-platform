# Copy to .env (or export in your shell) — never commit real values.

# Required for the dashboard: your Claude API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: model used to write site copy (default claude-sonnet-4-6).
# Use claude-opus-4-8 for max quality (higher cost).
DASHBOARD_MODEL=claude-sonnet-4-6

# Optional: dashboard port (default 5001)
PORT=5001

# Optional, only for `/deploy` to Cloudflare Pages
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
